@startuml TO-BE_Architecture_Hexagonale_Complete
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Architecture Hexagonale Complète - Good Food 3.0\nVue d'ensemble des Domaines et Ports

LAYOUT_WITH_LEGEND()

' ============================================
' EXTERNAL APPLICATIONS
' ============================================
System_Ext(web_app, "Application Web", "React", "Interface client web")
System_Ext(mobile_app, "Application Mobile", "React Native", "Interface client mobile")
System_Ext(driver_app, "App Livreur", "React Native", "Interface livreur")
System_Ext(franchise_app, "Dashboard Franchisé", "React", "Interface franchisé")
System_Ext(admin_app, "Admin Portal", "React", "Interface admin")

System_Ext(erp, "Dynamics 365", "ERP externe")
System_Ext(payment_provider, "BNB Bank", "Paiement")
System_Ext(pos_system, "Logiciel de Caisse", "POS")
System_Ext(sms_provider, "Service SMS", "Notifications")
System_Ext(email_provider, "Service Email", "SMTP")

' ============================================
' PRIMARY PORTS (Ports d'Entrée)
' ============================================
Container_Boundary(primary_ports, "🔌 PRIMARY PORTS (Adaptateurs d'Entrée)") {
    Component(rest_api, "REST API", "Spring Boot", "Points d'entrée HTTP")
    Component(graphql_api, "GraphQL API", "GraphQL Server", "API flexible")
    Component(webhook_handler, "Webhook Handler", "Event Listener", "Callbacks externes")
    Component(grpc_server, "gRPC Server", "gRPC", "Communication inter-services")
}

' ============================================
' COMMAND BUS & EVENT BUS
' ============================================
Container_Boundary(messaging, "📨 BUS DE COMMUNICATION") {
    Component(command_bus, "Command Bus", "MediatR/CQRS", "• Dispatche commandes\n• Validation\n• Traçabilité")
    Component(event_bus, "Event Bus", "RabbitMQ/Kafka", "• Publish/Subscribe\n• Event-Driven\n• Async messaging")
    Component(query_bus, "Query Bus", "CQRS", "• Séparation lecture\n• Optimisation queries")
}

' ============================================
' DOMAINS (Cœur Métier)
' ============================================
Container_Boundary(domains, "🏢 DOMAINES MÉTIER (Domain Layer)") {

    Container_Boundary(order_domain, "📦 Domaine COMMANDE") {
        Component(order_aggregate, "Order Aggregate", "DDD", "• Entités\n• Value Objects\n• Business Rules")
        Component(order_commands, "Order Commands", "CQRS", "• CreateOrder\n• UpdateOrder\n• CancelOrder")
        Component(order_events, "Order Events", "Domain Events", "• OrderCreated\n• OrderConfirmed\n• OrderCancelled")
        Component(order_services, "Order Services", "Domain Services", "• Pricing\n• Validation")
    }

    Container_Boundary(inventory_domain, "📊 Domaine STOCK") {
        Component(inventory_aggregate, "Inventory Aggregate", "DDD", "• Stock tracking\n• Réservations\n• Ruptures")
        Component(inventory_commands, "Inventory Commands", "CQRS", "• ReserveStock\n• ReleaseStock\n• UpdateStock")
        Component(inventory_events, "Inventory Events", "Domain Events", "• StockReserved\n• StockDepleted\n• StockReplenished")
    }

    Container_Boundary(logistics_domain, "🚚 Domaine LOGISTIQUE") {
        Component(logistics_aggregate, "Logistics Aggregate", "DDD", "• Livraisons\n• Tournées\n• Attribution")
        Component(logistics_commands, "Logistics Commands", "CQRS", "• AssignDriver\n• UpdateLocation\n• CompleteDelivery")
        Component(logistics_events, "Logistics Events", "Domain Events", "• DriverAssigned\n• DeliveryCompleted")
    }

    Container_Boundary(invoicing_domain, "💰 Domaine FACTURATION") {
        Component(invoicing_aggregate, "Invoicing Aggregate", "DDD", "• Factures\n• Paiements\n• Remboursements")
        Component(invoicing_commands, "Invoicing Commands", "CQRS", "• GenerateInvoice\n• ProcessPayment\n• IssueRefund")
        Component(invoicing_events, "Invoicing Events", "Domain Events", "• InvoiceGenerated\n• PaymentProcessed")
    }

    Container_Boundary(customer_domain, "👤 Domaine CLIENT") {
        Component(customer_aggregate, "Customer Aggregate", "DDD", "• Profils\n• Préférences\n• Fidélité")
        Component(customer_commands, "Customer Commands", "CQRS", "• RegisterCustomer\n• UpdateProfile")
        Component(customer_events, "Customer Events", "Domain Events", "• CustomerRegistered\n• ProfileUpdated")
    }

    Container_Boundary(restaurant_domain, "🏪 Domaine RESTAURANT") {
        Component(restaurant_aggregate, "Restaurant Aggregate", "DDD", "• Infos restaurant\n• Menu\n• Horaires")
        Component(restaurant_commands, "Restaurant Commands", "CQRS", "• UpdateMenu\n• SetHours")
        Component(restaurant_events, "Restaurant Events", "Domain Events", "• MenuUpdated\n• RestaurantClosed")
    }
}

' ============================================
' SECONDARY PORTS (Ports de Sortie)
' ============================================
Container_Boundary(secondary_ports, "🔌 SECONDARY PORTS (Adaptateurs de Sortie)") {
    Component(repository_ports, "Repository Ports", "Interfaces", "Contrats de persistance")
    Component(external_api_ports, "External API Ports", "Interfaces", "Contrats APIs externes")
    Component(notification_ports, "Notification Ports", "Interfaces", "Contrats notifications")
    Component(payment_ports, "Payment Ports", "Interfaces", "Contrats paiement")
}

' ============================================
' INFRASTRUCTURE (Implémentations)
' ============================================
Container_Boundary(infrastructure, "[INFRA] INFRASTRUCTURE LAYER") {
    Component(postgres_adapter, "PostgreSQL Adapter", "Repository Impl", "Persistence SQL")
    Component(mongodb_adapter, "MongoDB Adapter", "Repository Impl", "Documents/Logs")
    Component(redis_adapter, "Redis Adapter", "Cache Impl", "Cache distribué")

    Component(erp_adapter, "ERP Adapter", "API Client", "Sync Dynamics 365")
    Component(payment_adapter, "Payment Adapter", "API Client", "Paiements BNB")
    Component(pos_adapter, "POS Adapter", "API Client", "Logiciel caisse")

    Component(sms_adapter, "SMS Adapter", "API Client", "Envoi SMS")
    Component(email_adapter, "Email Adapter", "SMTP Client", "Envoi emails")
    Component(push_adapter, "Push Adapter", "Firebase", "Notifications push")
}

ContainerDb(postgres_db, "PostgreSQL", "Database", "• Commandes\n• Clients\n• Restaurants")
ContainerDb(mongodb_db, "MongoDB", "NoSQL", "• Logs\n• Events\n• Analytics")
ContainerDb(redis_cache, "Redis", "Cache", "• Sessions\n• Paniers\n• Requêtes")

' ============================================
' RELATIONS: EXTERNAL APPS → PRIMARY PORTS
' ============================================
Rel(web_app, graphql_api, "Queries/Mutations", "GraphQL")
Rel(mobile_app, graphql_api, "Queries/Mutations", "GraphQL")
Rel(driver_app, graphql_api, "Real-time updates", "GraphQL Subscriptions")
Rel(franchise_app, rest_api, "CRUD Operations", "REST")
Rel(admin_app, rest_api, "Admin operations", "REST")

Rel(payment_provider, webhook_handler, "Payment callbacks", "Webhook")
Rel(pos_system, webhook_handler, "Order notifications", "Webhook")

' ============================================
' RELATIONS: PRIMARY PORTS → COMMAND/EVENT BUS
' ============================================
Rel(rest_api, command_bus, "Dispatches commands")
Rel(graphql_api, command_bus, "Dispatches commands")
Rel(webhook_handler, command_bus, "Dispatches commands")
Rel(grpc_server, command_bus, "Dispatches commands")

Rel(rest_api, query_bus, "Queries")
Rel(graphql_api, query_bus, "Queries")

' ============================================
' RELATIONS: COMMAND BUS → DOMAINS
' ============================================
Rel(command_bus, order_commands, "Routes commands")
Rel(command_bus, inventory_commands, "Routes commands")
Rel(command_bus, logistics_commands, "Routes commands")
Rel(command_bus, invoicing_commands, "Routes commands")
Rel(command_bus, customer_commands, "Routes commands")
Rel(command_bus, restaurant_commands, "Routes commands")

' ============================================
' RELATIONS: DOMAINS → EVENT BUS
' ============================================
Rel(order_events, event_bus, "Publishes events")
Rel(inventory_events, event_bus, "Publishes events")
Rel(logistics_events, event_bus, "Publishes events")
Rel(invoicing_events, event_bus, "Publishes events")
Rel(customer_events, event_bus, "Publishes events")
Rel(restaurant_events, event_bus, "Publishes events")

' ============================================
' RELATIONS: DOMAINS → SECONDARY PORTS
' ============================================
Rel(order_aggregate, repository_ports, "Uses")
Rel(inventory_aggregate, repository_ports, "Uses")
Rel(logistics_aggregate, repository_ports, "Uses")
Rel(invoicing_aggregate, repository_ports, "Uses")

Rel(order_services, external_api_ports, "Uses")
Rel(invoicing_aggregate, payment_ports, "Uses")
Rel(logistics_aggregate, notification_ports, "Uses")

' ============================================
' RELATIONS: SECONDARY PORTS → INFRASTRUCTURE
' ============================================
Rel(repository_ports, postgres_adapter, "Implements")
Rel(repository_ports, mongodb_adapter, "Implements")
Rel(repository_ports, redis_adapter, "Implements")

Rel(external_api_ports, erp_adapter, "Implements")
Rel(external_api_ports, pos_adapter, "Implements")

Rel(payment_ports, payment_adapter, "Implements")

Rel(notification_ports, sms_adapter, "Implements")
Rel(notification_ports, email_adapter, "Implements")
Rel(notification_ports, push_adapter, "Implements")

' ============================================
' RELATIONS: INFRASTRUCTURE → EXTERNAL
' ============================================
Rel(postgres_adapter, postgres_db, "Reads/Writes", "SQL")
Rel(mongodb_adapter, mongodb_db, "Reads/Writes", "NoSQL")
Rel(redis_adapter, redis_cache, "Reads/Writes", "Redis Protocol")

Rel(erp_adapter, erp, "Syncs data", "REST API")
Rel(payment_adapter, payment_provider, "Processes payments", "REST API")
Rel(pos_adapter, pos_system, "Fetches orders", "Polling/API")

Rel(sms_adapter, sms_provider, "Sends SMS", "API")
Rel(email_adapter, email_provider, "Sends emails", "SMTP")

' ============================================
' RELATIONS: EVENT BUS → INFRASTRUCTURE
' ============================================
Rel(event_bus, erp_adapter, "Subscribes to events")
Rel(event_bus, sms_adapter, "Subscribes to events")
Rel(event_bus, email_adapter, "Subscribes to events")
Rel(event_bus, push_adapter, "Subscribes to events")

note right of domains
  **DOMAINES ISOLÉS:**

   Chaque domaine est autonome
   Communication par events uniquement
   Pas de dépendances directes
   Testable unitairement
   Évolutif indépendamment
end note

note left of command_bus
  **CQRS + EVENT SOURCING:**

  📝 **Command Bus**
  • Validation centralisée
  • Traçabilité complète
  • Retry automatique

  📡 **Event Bus**
  • Découplage total
  • Scalabilité horizontale
  • Async by default
end note

note bottom of secondary_ports
  **PORTS & ADAPTERS:**

  🔌 **Ports** = Interfaces (contrats)
  [INFRA] **Adapters** = Implémentations

   Changement facile d'implémentation
   Testable avec mocks
   Indépendance technologique
end note

footer Architecture Hexagonale Complète | Good Food 3.0 | CQRS + Event-Driven + DDD

@enduml
