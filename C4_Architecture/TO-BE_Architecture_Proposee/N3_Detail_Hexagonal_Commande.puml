@startuml TO-BE_Detail_Hexagonal_Commande
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Architecture Hexagonale - Service Commandes\nDétail de l'implémentation (Vue Technique)

LAYOUT_WITH_LEGEND()

Container(app, "Application Client", "Web/Mobile", "Interface utilisateur")

Container_Boundary(hexagonal_service, "Service Commandes - Architecture Hexagonale") {
    
    ' Couche externe - Ports d'entrée
    Container_Boundary(ports_in, "🔌 Ports d'Entrée") {
        Component(rest_controller, "REST Controller", "Spring Boot", "Point d'entrée HTTP")
        Component(graphql_resolver, "GraphQL Resolver", "GraphQL", "API flexible")
        Component(webhook_handler, "Webhook Handler", "Event Handler", "Événements externes")
    }
    
    ' Couche application - Cas d'usage
    Container_Boundary(application_layer, "📋 Couche Application") {
        Component(create_order_uc, "Créer Commande", "Use Case", "• Valide données\n• Orchestre le processus\n• Gère les erreurs")
        Component(update_order_uc, "Modifier Commande", "Use Case", "• Vérifie autorisation\n• Applique règles\n• Notifie changements")
        Component(cancel_order_uc, "Annuler Commande", "Use Case", "• Contrôle délais\n• Rembourse si nécessaire\n• Libère ressources")
    }
    
    ' Couche domaine - Cœur métier
    Container_Boundary(domain_layer, "🏢 Couche Domaine") {
        Component(order_entity, "Entité Commande", "Domain Entity", "• ID, statut, montant\n• Règles de validation\n• Invariants métier")
        Component(order_repository, "Repository Interface", "Port", "• Contrat de persistance\n• Indépendant de la DB")
        Component(pricing_service, "Service Tarification", "Domain Service", "• Calcul prix\n• Applique promotions\n• Règles tarifaires")
        Component(inventory_service, "Service Stock", "Domain Service", "• Vérifie disponibilité\n• Réserve produits\n• Gère ruptures")
    }
    
    ' Couche infrastructure - Adaptateurs
    Container_Boundary(adapters_layer, "🔌 Couche Infrastructure") {
        Component(postgres_adapter, "PostgreSQL Adapter", "Repository Impl", "• Implémente Repository\n• Requêtes SQL\n• Mapping ORM")
        Component(redis_adapter, "Redis Adapter", "Cache Impl", "• Cache paniers\n• Sessions\n• Performance")
        Component(erp_adapter, "ERP Adapter", "External API", "• Synchronisation\n• Données clients\n• Commandes")
        Component(payment_adapter, "Paiement Adapter", "External API", "• Traitement CB\n• Sécurisation\n• Confirmation")
        Component(event_publisher, "Event Publisher", "Message Queue", "• Commande créée\n• Statut changé\n• Notifications")
    }
}

ContainerDb(database, "PostgreSQL", "Database", "Données persistantes")
ContainerDb(cache, "Redis", "Cache", "Performance")
Container(queue, "Message Queue", "RabbitMQ", "Événements")

System_Ext(erp, "Dynamics 365", "ERP")
System_Ext(payment, "Service Paiement", "Banque")

' Flux de données
Rel(app, rest_controller, "1️⃣ POST /orders", "HTTP/JSON")
Rel(rest_controller, create_order_uc, "2️⃣ Délègue création")
Rel(create_order_uc, order_entity, "3️⃣ Crée entité")
Rel(create_order_uc, pricing_service, "4️⃣ Calcule prix")
Rel(create_order_uc, inventory_service, "5️⃣ Vérifie stock")

Rel(order_entity, order_repository, "6️⃣ Interface persistance")
Rel(order_repository, postgres_adapter, "7️⃣ Implémentation")
Rel(postgres_adapter, database, "8️⃣ Sauvegarde")

Rel(create_order_uc, payment_adapter, "9️⃣ Déclenche paiement")
Rel(payment_adapter, payment, "🔟 Traite CB")

Rel(create_order_uc, event_publisher, "1️⃣1️⃣ Publie événement")
Rel(event_publisher, queue, "1️⃣2️⃣ Message queue")
Rel(queue, erp_adapter, "1️⃣3️⃣ Sync ERP")
Rel(erp_adapter, erp, "1️⃣4️⃣ Mise à jour")

' Cache
Rel(create_order_uc, redis_adapter, "Cache panier")
Rel(redis_adapter, cache, "Stockage cache")

note right of domain_layer
  **CŒUR MÉTIER PROTÉGÉ:**
  
  🏢 **Entités riches**
  • Logique métier encapsulée
  • Validation des invariants
  • Pas de dépendance externe
  
  📋 **Services domaine**
  • Règles complexes
  • Orchestration métier
  • Calculs tarifaires
  
  🔒 **Isolation garantie**
  • Testable unitairement
  • Évolutif
  • Maintenable
end note

note bottom of adapters_layer
  **ADAPTATEURS FLEXIBLES:**
  
  🔌 **Changement facile**
  • PostgreSQL → MongoDB
  • Redis → Memcached
  • ERP → Autre système
  
  📡 **Communication**
  • REST, GraphQL, gRPC
  • Événements, Messages
  • Webhooks, APIs
  
  ⚡ **Performance**
  • Cache intelligent
  • Requêtes optimisées
  • Mise en cache
end note

note left of application_layer
  **CAS D'USAGE ORCHESTRÉS:**
  
  📋 **Créer Commande**
  1. Valide données
  2. Vérifie stock
  3. Calcule prix
  4. Crée entité
  5. Persiste
  6. Déclenche paiement
  7. Publie événement
  
  ✅ **Avantages**
  • Traçabilité complète
  • Gestion d'erreurs
  • Rollback possible
end note

footer Architecture Hexagonale - Service Commandes | Good Food 3.0

@enduml

