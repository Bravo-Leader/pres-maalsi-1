@startuml Detail_Livreur_Communication
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Architecture Hexagonale - Service Communication Livreur\nDétail technique VoIP et Sécurité

LAYOUT_WITH_LEGEND()

Container(app_livreur, "App Livreur", "React Native", "Interface livreur")

Container_Boundary(communication_service, "Service Communication Livreur - Architecture Hexagonale") {
    
    ' Couche externe - Ports d'entrée
    Container_Boundary(ports_in, "Ports d'Entrée") {
        Component(voip_controller, "VoIP Controller", "WebRTC", "Gestion appels VoIP")
        Component(emergency_controller, "Emergency Controller", "SOS Handler", "Gestion urgences")
        Component(location_controller, "Location Controller", "GPS Handler", "Géolocalisation")
    }
    
    ' Couche application - Cas d'usage
    Container_Boundary(application_layer, "Couche Application") {
        Component(initiate_call_uc, "Initier Appel", "Use Case", "• Sélection client\n• Connexion VoIP\n• Gestion erreurs")
        Component(handle_emergency_uc, "Gérer Urgence", "Use Case", "• Détection accident\n• Escalade automatique\n• Alerte secours")
        Component(share_location_uc, "Partager Position", "Use Case", "• GPS temps réel\n• Partage client/manager\n• Mise à jour continue")
        Component(record_interaction_uc, "Enregistrer Interaction", "Use Case", "• Enregistrement appels\n• Logs communication\n• Traçabilité")
    }
    
    ' Couche domaine - Cœur métier
    Container_Boundary(domain_layer, "Couche Domaine") {
        Component(communication_entity, "Entité Communication", "Domain Entity", "• Appels, SMS, Notifications\n• Statuts, horodatage\n• Règles de communication")
        Component(emergency_entity, "Entité Urgence", "Domain Entity", "• Type urgence\n• Gravité, localisation\n• Actions déclenchées")
        Component(communication_repository, "Repository Communication", "Port", "• Contrat de persistance\n• Historique appels")
        Component(voip_service, "Service VoIP", "Domain Service", "• Règles de connexion\n• Qualité audio\n• Sécurité")
        Component(emergency_service, "Service Urgences", "Domain Service", "• Détection accidents\n• Escalade automatique\n• Règles d'alerte")
        Component(location_service, "Service Géolocalisation", "Domain Service", "• Calcul position\n• Précision GPS\n• Partage sécurisé")
    }
    
    ' Couche infrastructure - Adaptateurs
    Container_Boundary(adapters_layer, "Couche Infrastructure") {
        Component(asterisk_adapter, "Asterisk Adapter", "VoIP Impl", "• Serveur PBX\n• Routage appels\n• Enregistrement")
        Component(webrtc_adapter, "WebRTC Adapter", "VoIP Impl", "• Communication P2P\n• Audio/Video\n• Sécurité")
        Component(accelerometer_adapter, "Accéléromètre Adapter", "Sensor Impl", "• Détection mouvements\n• Analyse patterns\n• Seuils d'alerte")
        Component(gps_adapter, "GPS Adapter", "Location Impl", "• Position précise\n• Mise à jour temps réel\n• Optimisation batterie")
        Component(emergency_api_adapter, "API Urgences Adapter", "External API", "• SAMU/Pompiers\n• Numéros d'urgence\n• Géolocalisation")
        Component(notification_adapter, "Notification Adapter", "Push/SMS", "• Alertes push\n• SMS automatiques\n• Notifications manager")
        Component(recording_adapter, "Recording Adapter", "Storage", "• Enregistrement appels\n• Stockage sécurisé\n• Conformité RGPD")
    }
}

ContainerDb(communication_db, "Communication DB", "PostgreSQL", "Historique appels")
ContainerDb(emergency_db, "Emergency DB", "PostgreSQL", "Logs urgences")
Container(voip_server, "Serveur VoIP", "Asterisk", "PBX entreprise")
Container(emergency_services, "Services Secours", "SAMU/Pompiers", "Urgences")

System_Ext(client, "👤 Client", "Destinataire")
System_Ext(manager, "👨‍💼 Manager", "Supervision")

' Flux de communication
Rel(app_livreur, voip_controller, "1️⃣ Initie appel client")
Rel(voip_controller, initiate_call_uc, "2️⃣ Délègue appel")
Rel(initiate_call_uc, communication_entity, "3️⃣ Crée entité communication")
Rel(initiate_call_uc, voip_service, "4️⃣ Règles VoIP")
Rel(voip_service, asterisk_adapter, "5️⃣ Connexion serveur")
Rel(asterisk_adapter, voip_server, "6️⃣ Routage appel")
Rel(voip_server, client, "7️⃣ Appel client")

' Flux urgence
Rel(app_livreur, emergency_controller, "🚨 Détection accident")
Rel(emergency_controller, handle_emergency_uc, "Délègue urgence")
Rel(handle_emergency_uc, emergency_entity, "Crée entité urgence")
Rel(handle_emergency_uc, emergency_service, "Règles urgence")
Rel(emergency_service, accelerometer_adapter, "Analyse capteurs")
Rel(emergency_service, emergency_api_adapter, "Appel secours")
Rel(emergency_api_adapter, emergency_services, "Alerte SAMU")

' Flux géolocalisation
Rel(app_livreur, location_controller, "📍 Position temps réel")
Rel(location_controller, share_location_uc, "Partage position")
Rel(share_location_uc, location_service, "Calcul position")
Rel(location_service, gps_adapter, "GPS précis")
Rel(share_location_uc, notification_adapter, "Notifie client/manager")

' Enregistrement
Rel(initiate_call_uc, record_interaction_uc, "Enregistre interaction")
Rel(record_interaction_uc, recording_adapter, "Stockage sécurisé")
Rel(recording_adapter, communication_db, "Persistance")

' Persistance
Rel(communication_entity, communication_repository, "Interface persistance")
Rel(communication_repository, communication_db, "Stocke historique")
Rel(emergency_entity, emergency_db, "Logs urgences")

