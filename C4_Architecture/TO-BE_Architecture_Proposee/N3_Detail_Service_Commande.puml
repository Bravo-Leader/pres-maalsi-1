@startuml TO-BE_Detail_Service_Commande
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Architecture PROPOSÉE - Service Commandes\nNiveau 3 : Détail Fonctionnel (Vue Business)

LAYOUT_WITH_LEGEND()

Container(app, "Application\nClient", "Web/Mobile", "Interface utilisateur")
ContainerDb(db, "Base de\nDonnées", "PostgreSQL", "Stockage sécurisé")
Container(cache, "Cache", "Redis", "Performance")
Container(queue, "File\nÉvénements", "RabbitMQ", "Communication")

Container_Ext(svc_menu, "Service\nMenus", "", "Catalogue")
Container_Ext(svc_payment, "Service\nPaiement", "", "Transactions")
Container_Ext(svc_delivery, "Service\nLivraison", "", "Organisation")
Container_Ext(erp, "ERP", "", "Synchronisation")

Container_Boundary(order_service, "Service Gestion Commandes") {
    
    Component(api, "🔌 Point d'Entrée", "API REST", "Reçoit les demandes\ndes clients")
    
    Component(validation, "✅ Validation", "Règles Métier", "• Vérifie disponibilité plats\n• Contrôle quantités\n• Valide adresse livraison\n• Applique promotions")
    
    Component(calcul, "🧮 Calcul", "Moteur Prix", "• Calcule total\n• Applique réductions\n• Calcule frais livraison\n• Gère taxes")
    
    Component(creation, "📝 Création", "Logique Commande", "• Crée la commande\n• Génère numéro unique\n• Réserve les plats\n• Définit statut initial")
    
    Component(persistence, "💾 Sauvegarde", "Accès Données", "• Enregistre commande\n• Historique client\n• Traçabilité complète")
    
    Component(events, "📣 Événements", "Event Publisher", "• Commande créée\n• Paiement requis\n• Livraison planifiée")
}

' Flux de traitement d'une commande
Rel(app, api, "1️⃣ Envoie commande", "JSON/HTTPS")

Rel(api, validation, "2️⃣ Vérifie validité")
Rel(validation, svc_menu, "Vérifie disponibilité", "API")

Rel(validation, calcul, "3️⃣ Si OK, calcule prix")

Rel(calcul, creation, "4️⃣ Crée commande")

Rel(creation, persistence, "5️⃣ Sauvegarde")
Rel(persistence, db, "Enregistre", "SQL")
Rel(persistence, cache, "Cache panier", "Redis")

Rel(creation, events, "6️⃣ Publie événements")
Rel(events, queue, "Événements métier", "AMQP")

Rel(queue, svc_payment, "Déclenche paiement")
Rel(queue, svc_delivery, "Planifie livraison")
Rel(queue, erp, "Synchronise")

note right of order_service
  **AVANTAGES BUSINESS:**
  
  ✅ **Fiabilité**
  5 étapes de validation
  Zéro erreur de commande
  
  ✅ **Rapidité**
  Traitement < 500ms
  Expérience fluide
  
  ✅ **Traçabilité**
  Chaque étape enregistrée
  Audit complet possible
  
  ✅ **Évolutivité**
  Ajout règles métier facile
  Pas d'impact sur existant
end note

note bottom of validation
  **CONTRÔLES QUALITÉ:**
  
  1. Plats disponibles ?
  2. Restaurant ouvert ?
  3. Adresse valide ?
  4. Code promo valide ?
  5. Montant minimum atteint ?
  
  → Si 1 seul NON = Commande refusée
     avec message clair au client
end note

note top of events
  **ÉVÉNEMENTS PUBLIÉS:**
  
  📢 "CommandeCreee"
  → Déclenche paiement
  
  📢 "CommandeValidee"  
  → Déclenche livraison
  
  📢 "CommandeLivree"
  → Met à jour ERP
  
  **BÉNÉFICE:**
  Communication asynchrone
  = Pas de blocage
end note

footer Architecture TO-BE - Service robuste et performant | Good Food 3.0

UpdateElementStyle("modern", $bgColor="#B3FFB3", $borderColor="#00AA00")

@enduml

