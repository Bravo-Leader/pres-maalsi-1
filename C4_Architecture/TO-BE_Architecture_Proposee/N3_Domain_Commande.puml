@startuml N3_Domain_Commande
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Domaine COMMANDE - Architecture Détaillée\nCQRS + Event Sourcing + DDD

LAYOUT_WITH_LEGEND()

' ============================================
' PRIMARY ADAPTERS (Entrées)
' ============================================
Component(graphql_resolver, "GraphQL Resolver", "Apollo Server", "Mutations/Queries")
Component(rest_controller, "REST Controller", "Spring Boot", "HTTP endpoints")
Component(webhook_listener, "Webhook Listener", "Event Handler", "External callbacks")

' ============================================
' COMMAND BUS
' ============================================
Container_Boundary(command_side, "📝 COMMAND SIDE (Write)") {
    Component(command_bus, "Command Bus", "MediatR", "Dispatche les commandes")

    Container_Boundary(commands, "Commands") {
        Component(create_order_cmd, "CreateOrderCommand", "DTO", "• customerId\n• items[]\n• deliveryAddress\n• paymentMethod")
        Component(update_order_cmd, "UpdateOrderCommand", "DTO", "• orderId\n• status\n• updates")
        Component(cancel_order_cmd, "CancelOrderCommand", "DTO", "• orderId\n• reason\n• refundAmount")
        Component(confirm_payment_cmd, "ConfirmPaymentCommand", "DTO", "• orderId\n• transactionId\n• amount")
    }

    Container_Boundary(command_handlers, "Command Handlers") {
        Component(create_order_handler, "CreateOrderHandler", "Handler", "Orchestrates order creation")
        Component(update_order_handler, "UpdateOrderHandler", "Handler", "Manages order updates")
        Component(cancel_order_handler, "CancelOrderHandler", "Handler", "Handles cancellation logic")
        Component(confirm_payment_handler, "ConfirmPaymentHandler", "Handler", "Confirms payment")
    }
}

' ============================================
' DOMAIN LAYER
' ============================================
Container_Boundary(domain_layer, "🏢 DOMAIN LAYER") {

    Container_Boundary(aggregates, "Aggregates") {
        Component(order_aggregate, "Order Aggregate", "Aggregate Root", "**State:**\n• orderId\n• customerId\n• status\n• items\n• totalAmount\n• createdAt\n\n**Methods:**\n• create()\n• confirm()\n• cancel()\n• updateStatus()")

        Component(order_item, "OrderItem", "Entity", "• productId\n• quantity\n• unitPrice\n• subtotal")

        Component(delivery_info, "DeliveryInfo", "Value Object", "• address\n• eta\n• driverId\n• instructions")

        Component(payment_info, "PaymentInfo", "Value Object", "• method\n• status\n• transactionId\n• paidAt")
    }

    Container_Boundary(domain_services, "Domain Services") {
        Component(pricing_service, "PricingService", "Domain Service", "• calculateTotal()\n• applyPromotion()\n• calculateDeliveryFee()\n• applyLoyaltyPoints()")

        Component(validation_service, "ValidationService", "Domain Service", "• validateOrder()\n• checkMinimumAmount()\n• verifyDeliveryZone()\n• validatePaymentMethod()")

        Component(inventory_checker, "InventoryChecker", "Domain Service", "• checkAvailability()\n• reserveItems()\n• releaseItems()")
    }

    Container_Boundary(domain_events, "Domain Events") {
        Component(order_created_event, "OrderCreatedEvent", "Event", "• orderId\n• customerId\n• items\n• total\n• timestamp")
        Component(order_confirmed_event, "OrderConfirmedEvent", "Event", "• orderId\n• confirmedAt")
        Component(order_cancelled_event, "OrderCancelledEvent", "Event", "• orderId\n• reason\n• cancelledAt")
        Component(payment_confirmed_event, "PaymentConfirmedEvent", "Event", "• orderId\n• transactionId\n• amount")
    }

    Container_Boundary(repositories, "Repository Interfaces (Ports)") {
        Component(order_repository, "IOrderRepository", "Port", "• save(order)\n• findById(id)\n• findByCustomer(id)\n• delete(id)")
        Component(event_store, "IEventStore", "Port", "• append(events)\n• getEvents(aggregateId)\n• replay()")
    }

    Container_Boundary(external_ports, "External Service Ports") {
        Component(payment_gateway_port, "IPaymentGateway", "Port", "• processPayment()\n• refund()\n• getStatus()")
        Component(inventory_port, "IInventoryService", "Port", "• checkStock()\n• reserve()\n• release()")
        Component(notification_port, "INotificationService", "Port", "• sendEmail()\n• sendSMS()\n• sendPush()")
    }
}

' ============================================
' QUERY SIDE (CQRS Read)
' ============================================
Container_Boundary(query_side, "📖 QUERY SIDE (Read)") {
    Component(query_bus, "Query Bus", "MediatR", "Dispatche les queries")

    Container_Boundary(queries, "Queries") {
        Component(get_order_query, "GetOrderQuery", "DTO", "• orderId")
        Component(list_orders_query, "ListOrdersQuery", "DTO", "• customerId\n• status\n• pagination")
        Component(order_history_query, "OrderHistoryQuery", "DTO", "• customerId\n• dateRange")
    }

    Container_Boundary(query_handlers, "Query Handlers") {
        Component(get_order_handler, "GetOrderHandler", "Handler", "Fetches single order")
        Component(list_orders_handler, "ListOrdersHandler", "Handler", "Lists orders with filters")
        Component(order_history_handler, "OrderHistoryHandler", "Handler", "Returns history")
    }

    Container_Boundary(read_models, "Read Models (Projections)") {
        Component(order_view, "OrderView", "DTO", "Optimized for reading")
        Component(order_summary_view, "OrderSummaryView", "DTO", "List view")
        Component(order_history_view, "OrderHistoryView", "DTO", "History view")
    }

    Component(read_repository, "OrderReadRepository", "Read Store", "• getOrder(id)\n• listOrders(filters)\n• search(criteria)")
}

' ============================================
' EVENT BUS
' ============================================
Component(event_bus, "Event Bus", "RabbitMQ/Kafka", "Publish/Subscribe")

Container_Boundary(event_handlers, "Event Handlers (Subscribers)") {
    Component(projection_updater, "ProjectionUpdater", "Handler", "Updates read models")
    Component(notification_handler, "NotificationHandler", "Handler", "Sends notifications")
    Component(analytics_handler, "AnalyticsHandler", "Handler", "Tracks metrics")
    Component(erp_sync_handler, "ERPSyncHandler", "Handler", "Syncs to ERP")
}

' ============================================
' INFRASTRUCTURE (Secondary Adapters)
' ============================================
Container_Boundary(infrastructure, "⚙️ INFRASTRUCTURE LAYER") {
    Component(postgres_adapter, "PostgresOrderRepository", "Adapter", "Implements IOrderRepository")
    Component(event_store_adapter, "EventStoreAdapter", "Adapter", "Event sourcing storage")
    Component(redis_read_adapter, "RedisReadRepository", "Adapter", "Cached read models")

    Component(payment_adapter, "BNBPaymentAdapter", "Adapter", "Implements IPaymentGateway")
    Component(inventory_adapter, "InventoryServiceAdapter", "Adapter", "Implements IInventoryService")
    Component(email_adapter, "EmailNotificationAdapter", "Adapter", "Implements INotificationService")
}

ContainerDb(postgres_db, "PostgreSQL", "Write DB", "Event-sourced orders")
ContainerDb(event_store_db, "Event Store", "EventStoreDB", "Event history")
ContainerDb(redis_db, "Redis", "Read Cache", "Projections")
System_Ext(payment_api, "BNB Payment API", "External")
System_Ext(inventory_service, "Inventory Service", "Microservice")
System_Ext(email_service, "Email Service", "External")

' ============================================
' FLOW: COMMAND SIDE (Write)
' ============================================
Rel(graphql_resolver, command_bus, "1. Dispatches", "CreateOrderCommand")
Rel(command_bus, create_order_cmd, "2. Routes to")
Rel(create_order_cmd, create_order_handler, "3. Handled by")

Rel(create_order_handler, validation_service, "4. Validates")
Rel(create_order_handler, pricing_service, "5. Calculates price")
Rel(create_order_handler, inventory_checker, "6. Checks stock")
Rel(create_order_handler, order_aggregate, "7. Creates aggregate")

Rel(order_aggregate, order_created_event, "8. Raises event")
Rel(order_aggregate, order_repository, "9. Persists via port")
Rel(order_repository, postgres_adapter, "10. Implemented by")
Rel(postgres_adapter, postgres_db, "11. Writes to")

Rel(order_aggregate, event_store, "12. Stores events")
Rel(event_store, event_store_adapter, "13. Implemented by")
Rel(event_store_adapter, event_store_db, "14. Appends to")

' ============================================
' FLOW: EVENT PUBLISHING
' ============================================
Rel(order_created_event, event_bus, "15. Publishes")
Rel(event_bus, projection_updater, "16. Notifies")
Rel(projection_updater, read_repository, "17. Updates read model")
Rel(read_repository, redis_read_adapter, "18. Caches")
Rel(redis_read_adapter, redis_db, "19. Stores")

Rel(event_bus, notification_handler, "20. Notifies")
Rel(notification_handler, notification_port, "21. Sends via port")
Rel(notification_port, email_adapter, "22. Implemented by")
Rel(email_adapter, email_service, "23. Sends email")

Rel(event_bus, erp_sync_handler, "24. Syncs")

' ============================================
' FLOW: EXTERNAL SERVICES
' ============================================
Rel(create_order_handler, payment_gateway_port, "Processes payment")
Rel(payment_gateway_port, payment_adapter, "Implemented by")
Rel(payment_adapter, payment_api, "Calls")

Rel(create_order_handler, inventory_port, "Reserves stock")
Rel(inventory_port, inventory_adapter, "Implemented by")
Rel(inventory_adapter, inventory_service, "Calls")

' ============================================
' FLOW: QUERY SIDE (Read)
' ============================================
Rel(graphql_resolver, query_bus, "Queries", "GetOrderQuery")
Rel(query_bus, get_order_query, "Routes")
Rel(get_order_query, get_order_handler, "Handled by")
Rel(get_order_handler, read_repository, "Reads from")
Rel(read_repository, redis_db, "Fetches cached", "Fast!")

note right of domain_layer
  **DDD TACTICAL PATTERNS:**

  🏢 **Aggregate Root**: Order
  • Maintains invariants
  • Transactional boundary
  • Generates domain events

  💎 **Value Objects**:
  • DeliveryInfo (immutable)
  • PaymentInfo (immutable)

  ⚙️ **Domain Services**:
  • Complex business logic
  • Multi-aggregate operations

  📡 **Events**: Communication
end note

note left of command_side
  **CQRS PATTERN:**

  ✍️ **Write Side**
  • Commands modify state
  • Event-sourced
  • Strong consistency

  📖 **Read Side**
  • Queries read projections
  • Optimized for queries
  • Eventually consistent
  • Cached in Redis
end note

note bottom of event_bus
  **EVENT-DRIVEN BENEFITS:**

  ✅ Loose coupling
  ✅ Scalability
  ✅ Audit trail
  ✅ Replay capability
  ✅ Async processing
  ✅ Multiple subscribers
end note

footer Domaine COMMANDE - CQRS + Event Sourcing + DDD | Good Food 3.0

@enduml
