@startuml N3_Component_InventoryService
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Service INVENTAIRE - Niveau 3: Composants\nArchitecture Hexagonale - Gestion des Stocks

LAYOUT_WITH_LEGEND()

Container(rest_api, "REST API", "Express", "API gestion stocks")
Container(event_bus_ext, "Event Bus", "RabbitMQ", "OrderCreated, OrderCancelled")

' ====================
' PRIMARY ADAPTERS (Entrée)
' ====================
Container_Boundary(primary_adapters, "🔌 PRIMARY ADAPTERS (Entrée)") {
    Component(stock_controller, "Stock Controller", "REST", "• GET /stock/:id\n• POST /stock/check\n• PATCH /stock/:id")

    Component(order_event_listener, "Order Event Listener", "RabbitMQ Consumer", "• OrderCreated\n• OrderCancelled")

    Component(pos_sync, "POS Sync", "Scheduled Job", "Synchronise avec caisse\n(toutes les 5 min)")
}

' ====================
' APPLICATION LAYER
' ====================
Container_Boundary(application, "📋 APPLICATION LAYER") {
    Component(reserve_stock_usecase, "ReserveStockUseCase", "Use Case", "**Orchestrates:**\n1. Vérifier disponibilité\n2. Créer réservation (15 min)\n3. Déduire du stock\n4. Publier événement")

    Component(release_stock_usecase, "ReleaseStockUseCase", "Use Case", "**Orchestrates:**\n1. Charger réservation\n2. Libérer quantité\n3. Rajouter au stock\n4. Publier événement")

    Component(update_stock_usecase, "UpdateStockUseCase", "Use Case", "**Orchestrates:**\n1. Valider quantité\n2. Mettre à jour stock\n3. Vérifier seuil\n4. Alerter si bas")
}

' ====================
' DOMAIN LAYER (Cœur Métier)
' ====================
Container_Boundary(domain, "🏢 DOMAIN LAYER (Cœur Hexagone)") {

    Container_Boundary(aggregates, "Aggregates") {
        Component(inventory, "Inventory", "Aggregate Root", "**État:**\n• productId\n• restaurantId\n• available\n• reserved\n• minThreshold\n• lastUpdated\n\n**Méthodes:**\n• reserve(qty)\n• release(reservationId)\n• updateStock(qty)\n• isAvailable(qty)")

        Component(reservation, "Reservation", "Entity", "• reservationId\n• orderId\n• items[]\n• expiresAt (15 min)\n• cancel()")
    }

    Container_Boundary(value_objects, "Value Objects") {
        Component(quantity, "Quantity", "Value Object", "• value\n• unit\n• validate()")

        Component(threshold, "Threshold", "Value Object", "• min\n• max\n• reorderPoint")
    }

    Container_Boundary(domain_services, "Domain Services") {
        Component(availability_checker, "AvailabilityChecker", "Domain Service", "**Vérifie:**\n• Stock disponible\n• Réservations actives\n• Formule:\n  available = total - reserved")

        Component(alert_service, "AlertService", "Domain Service", "**Alerte si:**\n• stock < minThreshold\n• stock = 0\n• Produit expiré")
    }

    Container_Boundary(domain_events, "Domain Events") {
        Component(stock_reserved_event, "StockReservedEvent", "Event", "• reservationId\n• productId\n• quantity")

        Component(stock_released_event, "StockReleasedEvent", "Event", "• reservationId\n• quantity")

        Component(low_stock_alert, "LowStockAlertEvent", "Event", "• productId\n• currentQty\n• threshold")
    }

    Container_Boundary(ports_interfaces, "Ports (Interfaces)") {
        Component(inventory_repo_port, "IInventoryRepository", "Port", "• save(inventory)\n• findByProduct(id)\n• findByRestaurant(id)")

        Component(reservation_repo_port, "IReservationRepository", "Port", "• save(reservation)\n• findById(id)\n• findExpired()")

        Component(notification_port, "INotificationService", "Port", "• alertLowStock()\n• notifyRestaurant()")
    }
}

' ====================
' SECONDARY ADAPTERS (Sortie)
' ====================
Container_Boundary(secondary_adapters, "⚙️ SECONDARY ADAPTERS (Sortie)") {
    Component(postgres_adapter, "PostgresInventoryRepository", "Adapter", "**Implémente:** IInventoryRepository\n\n• INSERT INTO inventory\n• UPDATE inventory\n• SELECT stock levels")

    Component(redis_adapter, "RedisReservationRepository", "Adapter", "**Implémente:** IReservationRepository\n\n• SETEX reservation 900 (15 min)\n• GET reservation\n• TTL auto-expire")

    Component(email_adapter, "EmailNotificationAdapter", "Adapter", "**Implémente:** INotificationService\n\n• Send low stock alert\n• Notify restaurant manager")

    Component(event_publisher, "RabbitMQPublisher", "Adapter", "**Publie événements**\n\n• exchange: stock\n• routing key: stock.*")
}

' ====================
' INFRASTRUCTURE
' ====================
ContainerDb(postgres_db, "PostgreSQL", "Database", "inventory table")
ContainerDb(redis_db, "Redis", "Cache", "reservations (TTL)")
System_Ext(email_service, "Email Service", "SMTP", "Alerts")
System_Ext(pos_system, "POS System", "External", "Caisse restaurant")

' ====================
' FLOW: RESERVE STOCK (OrderCreated)
' ====================
Rel(event_bus_ext, order_event_listener, "1. OrderCreatedEvent", "AMQP")
Rel(order_event_listener, reserve_stock_usecase, "2. Execute", "Command")

Rel(reserve_stock_usecase, availability_checker, "3. Check stock", "Domain call")
Rel(reserve_stock_usecase, inventory, "4. Reserve", "Aggregate method")
Rel(inventory, reservation, "5. Create reservation", "Entity")

Rel(inventory, stock_reserved_event, "6. Raises event", "Domain event")

Rel(reserve_stock_usecase, inventory_repo_port, "7. Save inventory", "Port interface")
Rel(inventory_repo_port, postgres_adapter, "8. Implements", "Adapter")
Rel(postgres_adapter, postgres_db, "9. UPDATE", "SQL")

Rel(reserve_stock_usecase, reservation_repo_port, "10. Save reservation", "Port interface")
Rel(reservation_repo_port, redis_adapter, "11. Implements", "Adapter")
Rel(redis_adapter, redis_db, "12. SETEX 15min", "Redis")

Rel(stock_reserved_event, event_publisher, "13. Publish", "Event")
Rel(event_publisher, event_bus_ext, "14. Send", "AMQP")

' ====================
' FLOW: LOW STOCK ALERT
' ====================
Rel(update_stock_usecase, alert_service, "Check threshold", "Domain service")
Rel(alert_service, low_stock_alert, "Raises alert", "Event")
Rel(low_stock_alert, notification_port, "Send alert", "Port")
Rel(notification_port, email_adapter, "Implements", "Adapter")
Rel(email_adapter, email_service, "Send email", "SMTP")

' ====================
' FLOW: POS SYNC
' ====================
Rel(pos_sync, pos_system, "Fetch current stock", "HTTP")
Rel(pos_sync, update_stock_usecase, "Update stock", "Command")

' ====================
' FLOW: QUERY STOCK
' ====================
Rel(rest_api, stock_controller, "GET /stock/:id", "HTTP")
Rel(stock_controller, inventory_repo_port, "Find by product", "Port")
Rel(inventory_repo_port, postgres_adapter, "Query", "SQL")

' ====================
' NOTES
' ====================
note right of domain
  **BUSINESS RULES**

  📦 **Stock disponible:**
  available = total - reserved

  ⏰ **Réservation:**
  • Durée: 15 minutes
  • Auto-expire si non confirmée
  • Libéré si commande annulée

  🔔 **Alertes:**
  • stock < minThreshold → Alert
  • stock = 0 → Out of stock

  **Benefits:**
  ✅ Évite overselling
  ✅ Optimise stocks
  ✅ Auto-alertes
end note

note left of primary_adapters
  **ENTRÉES DU SYSTÈME**

  🌐 **REST API:**
  • Gestion manuelle stocks
  • Consultation inventaire

  📨 **Event Listener:**
  • Réagit aux commandes
  • Synchronisation asynchrone

  🔄 **POS Sync:**
  • Synchronise caisse restaurant
  • Toutes les 5 minutes
end note

note bottom of secondary_adapters
  **SORTIES DU SYSTÈME**

  **Pattern Adapter:**
  • Port = Interface (contrat)
  • Adapter = Implémentation

  **Redis pour réservations:**
  • TTL auto-expire (15 min)
  • Pas besoin de job cleanup
  • Performant

  **PostgreSQL pour stock:**
  • Durabilité
  • Transactions ACID
  • Audit trail
end note

note as n1
  **FLUX: Réserver Stock**

  1️⃣ **Event Bus** reçoit OrderCreatedEvent
  2️⃣ **Listener** consomme l'événement
  3️⃣ **Use Case** orchestre:
     • Vérifie disponibilité (Domain Service)
     • Crée réservation (Aggregate)
     • Sauve dans Postgres (stock)
     • Sauve dans Redis (réservation avec TTL)
     • Publie StockReservedEvent

  ⏱️ **Temps total: < 100ms**

  **Gestion TTL:**
  Si commande non confirmée en 15 min:
  • Redis expire automatiquement
  • Job cleanup libère le stock
end note

footer Service INVENTAIRE - N3 Components | Architecture Hexagonale

@enduml
