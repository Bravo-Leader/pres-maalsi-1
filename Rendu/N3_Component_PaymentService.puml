@startuml N3_Component_PaymentService
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Service FACTURATION - Niveau 3: Composants\nArchitecture Hexagonale - Paiements et Factures

LAYOUT_WITH_LEGEND()

Container(payment_api, "Payment API", "Express", "API paiements")
Container(webhook_receiver, "Webhook Receiver", "HTTP", "BNB Bank webhooks")
Container(event_bus_ext, "Event Bus", "RabbitMQ", "OrderCreated, OrderCancelled")

' ====================
' PRIMARY ADAPTERS (Entrée)
' ====================
Container_Boundary(primary_adapters, "🔌 PRIMARY ADAPTERS (Entrée)") {
    Component(payment_controller, "Payment Controller", "REST", "• POST /payments\n• GET /payments/:id\n• POST /refunds")

    Component(bnb_webhook, "BNB Webhook Handler", "HTTP Handler", "• payment.success\n• payment.failed\n• refund.processed")

    Component(order_event_listener, "Order Event Listener", "RabbitMQ Consumer", "• OrderCreated\n→ Génère facture")
}

' ====================
' APPLICATION LAYER
' ====================
Container_Boundary(application, "📋 APPLICATION LAYER") {
    Component(process_payment_usecase, "ProcessPaymentUseCase", "Use Case", "**Orchestrates:**\n1. Valider montant\n2. Vérifier fraude\n3. Traiter paiement\n4. Générer facture")

    Component(confirm_payment_usecase, "ConfirmPaymentUseCase", "Use Case", "**Orchestrates:**\n1. Valider webhook\n2. Confirmer paiement\n3. Publier événement\n4. Mettre à jour commande")

    Component(issue_refund_usecase, "IssueRefundUseCase", "Use Case", "**Orchestrates:**\n1. Calculer montant\n2. Vérifier éligibilité\n3. Traiter remboursement\n4. Mettre à jour facture")

    Component(generate_invoice_usecase, "GenerateInvoiceUseCase", "Use Case", "**Orchestrates:**\n1. Récupérer détails commande\n2. Calculer taxes (TVA)\n3. Générer PDF\n4. Envoyer par email")
}

' ====================
' DOMAIN LAYER (Cœur Métier)
' ====================
Container_Boundary(domain, "🏢 DOMAIN LAYER (Cœur Hexagone)") {

    Container_Boundary(aggregates, "Aggregates") {
        Component(payment, "Payment", "Aggregate Root", "**État:**\n• paymentId\n• orderId\n• amount\n• status\n• method\n• transactionId\n• createdAt\n• completedAt\n\n**Méthodes:**\n• initiate()\n• confirm()\n• fail()\n• refund()")

        Component(invoice, "Invoice", "Aggregate Root", "**État:**\n• invoiceId\n• invoiceNumber\n• orderId\n• items[]\n• subtotal\n• taxAmount (TVA 20%)\n• totalAmount\n• paidAt\n\n**Méthodes:**\n• generate()\n• markAsPaid()\n• cancel()")

        Component(refund, "Refund", "Entity", "• refundId\n• paymentId\n• amount\n• reason\n• status\n• processedAt")
    }

    Container_Boundary(value_objects, "Value Objects") {
        Component(money, "Money", "Value Object", "• amount\n• currency (EUR)\n• format()")

        Component(tax, "TaxAmount", "Value Object", "• rate (20%)\n• amount\n• calculate()")

        Component(payment_method, "PaymentMethod", "Value Object", "• type (CARD/CASH)\n• last4\n• brand")
    }

    Container_Boundary(domain_services, "Domain Services") {
        Component(pricing_calculator, "PricingCalculator", "Domain Service", "**Calcule:**\n• Sous-total articles\n• Frais livraison\n• Service charge (2€)\n• Commission (15%)")

        Component(tax_calculator, "TaxCalculator", "Domain Service", "**Calcule TVA:**\n• 20% sur nourriture\n• 5.5% sur boissons\n• Breakdown détaillé")

        Component(fraud_detector, "FraudDetector", "Domain Service", "**Détecte:**\n• Montant anormal\n• Adresse suspecte\n• Carte bloquée\n• Score risque < 50")

        Component(refund_calculator, "RefundCalculator", "Domain Service", "**Politique:**\n• < 5 min: 100%\n• < 30 min: 90%\n• Livré: 0%")
    }

    Container_Boundary(domain_events, "Domain Events") {
        Component(payment_initiated_event, "PaymentInitiatedEvent", "Event", "• paymentId\n• orderId\n• amount")

        Component(payment_confirmed_event, "PaymentConfirmedEvent", "Event", "• paymentId\n• transactionId\n• paidAt")

        Component(payment_failed_event, "PaymentFailedEvent", "Event", "• paymentId\n• reason\n• failedAt")

        Component(invoice_generated_event, "InvoiceGeneratedEvent", "Event", "• invoiceId\n• orderId\n• pdfUrl")

        Component(refund_processed_event, "RefundProcessedEvent", "Event", "• refundId\n• amount\n• processedAt")
    }

    Container_Boundary(ports_interfaces, "Ports (Interfaces)") {
        Component(payment_repo_port, "IPaymentRepository", "Port", "• save(payment)\n• findById(id)\n• findByOrder(orderId)")

        Component(invoice_repo_port, "IInvoiceRepository", "Port", "• save(invoice)\n• findById(id)\n• findByOrder(orderId)")

        Component(payment_gateway_port, "IPaymentGateway", "Port", "• charge(amount)\n• refund(transactionId)\n• getStatus()")

        Component(fraud_detection_port, "IFraudDetection", "Port", "• analyzeTransaction()\n• scoreRisk()\n• blockSuspicious()")

        Component(invoice_generator_port, "IInvoiceGenerator", "Port", "• generatePDF()\n• sendEmail()")
    }
}

' ====================
' SECONDARY ADAPTERS (Sortie)
' ====================
Container_Boundary(secondary_adapters, "⚙️ SECONDARY ADAPTERS (Sortie)") {
    Component(postgres_adapter, "PostgresPaymentRepository", "Adapter", "**Implémente:** IPaymentRepository\n\n• INSERT INTO payments\n• UPDATE payment_status\n• Transactionnel (ACID)")

    Component(bnb_adapter, "BNBBankAdapter", "Adapter", "**Implémente:** IPaymentGateway\n\n• BNB Bank API\n• 3D Secure (SCA)\n• PCI-DSS compliant")

    Component(sift_adapter, "SiftFraudAdapter", "Adapter", "**Implémente:** IFraudDetection\n\n• Machine learning scoring\n• Real-time analysis\n• Risk score 0-100")

    Component(pdf_adapter, "PDFGeneratorAdapter", "Adapter", "**Implémente:** IInvoiceGenerator\n\n• PDFKit library\n• Email via SendGrid\n• S3 storage")

    Component(event_publisher, "RabbitMQPublisher", "Adapter", "**Publie événements**\n\n• exchange: payments\n• routing key: payment.*\n• durable: true")
}

' ====================
' INFRASTRUCTURE
' ====================
ContainerDb(postgres_db, "PostgreSQL", "Database", "payments, invoices")
ContainerDb(s3_storage, "AWS S3", "Object Storage", "PDF invoices")
System_Ext(bnb_bank, "BNB Bank", "Payment Gateway", "Cartes bancaires")
System_Ext(sift, "Sift Science", "External", "Fraud detection")
System_Ext(sendgrid, "SendGrid", "Email Service", "Invoice delivery")

' ====================
' FLOW: PROCESS PAYMENT
' ====================
Rel(payment_api, payment_controller, "1. POST /payments", "HTTP")
Rel(payment_controller, process_payment_usecase, "2. Execute", "Command")

Rel(process_payment_usecase, fraud_detector, "3. Check fraud", "Domain service")
Rel(fraud_detector, fraud_detection_port, "4. Analyze", "Port interface")
Rel(fraud_detection_port, sift_adapter, "5. Implements", "Adapter")
Rel(sift_adapter, sift, "6. Risk score API", "HTTPS")

Rel(process_payment_usecase, payment, "7. Initiate payment", "Aggregate method")
Rel(payment, payment_initiated_event, "8. Raises event", "Domain event")

Rel(process_payment_usecase, payment_gateway_port, "9. Charge card", "Port interface")
Rel(payment_gateway_port, bnb_adapter, "10. Implements", "Adapter")
Rel(bnb_adapter, bnb_bank, "11. BNB Bank API", "HTTPS 3D Secure")

Rel(process_payment_usecase, payment_repo_port, "12. Save", "Port interface")
Rel(payment_repo_port, postgres_adapter, "13. Implements", "Adapter")
Rel(postgres_adapter, postgres_db, "14. INSERT", "SQL")

' ====================
' FLOW: WEBHOOK CONFIRMATION
' ====================
Rel(bnb_bank, webhook_receiver, "payment.success", "HTTPS Webhook")
Rel(webhook_receiver, bnb_webhook, "Verify signature", "Handler")
Rel(bnb_webhook, confirm_payment_usecase, "Execute", "Command")

Rel(confirm_payment_usecase, payment, "Confirm payment", "Aggregate method")
Rel(payment, payment_confirmed_event, "Raises event", "Domain event")

Rel(payment_confirmed_event, event_publisher, "Publish", "Event")
Rel(event_publisher, event_bus_ext, "Send", "AMQP")

' ====================
' FLOW: GENERATE INVOICE
' ====================
Rel(event_bus_ext, order_event_listener, "OrderCreatedEvent", "AMQP")
Rel(order_event_listener, generate_invoice_usecase, "Execute", "Command")

Rel(generate_invoice_usecase, pricing_calculator, "Calculate totals", "Domain service")
Rel(generate_invoice_usecase, tax_calculator, "Calculate VAT", "Domain service")

Rel(generate_invoice_usecase, invoice, "Generate invoice", "Aggregate method")
Rel(invoice, invoice_generated_event, "Raises event", "Domain event")

Rel(generate_invoice_usecase, invoice_generator_port, "Generate PDF", "Port interface")
Rel(invoice_generator_port, pdf_adapter, "Implements", "Adapter")
Rel(pdf_adapter, s3_storage, "Upload PDF", "S3 API")
Rel(pdf_adapter, sendgrid, "Send email", "SMTP")

' ====================
' FLOW: REFUND
' ====================
Rel(payment_api, payment_controller, "POST /refunds", "HTTP")
Rel(payment_controller, issue_refund_usecase, "Execute", "Command")

Rel(issue_refund_usecase, refund_calculator, "Calculate amount", "Domain service")
Rel(issue_refund_usecase, payment, "Create refund", "Aggregate method")

Rel(payment, payment_gateway_port, "Process refund", "Port")
Rel(payment_gateway_port, bnb_adapter, "Implements", "Adapter")
Rel(bnb_adapter, bnb_bank, "Refund API", "HTTPS")

Rel(payment, refund_processed_event, "Raises event", "Domain event")
Rel(refund_processed_event, event_publisher, "Publish", "Event")

' ====================
' NOTES
' ====================
note right of domain
  **BUSINESS RULES**

  💳 **Paiement:**
  • 3D Secure > 30€ obligatoire
  • PCI-DSS compliant
  • Pas de stockage carte
  • Score fraude < 50

  💸 **Remboursement:**
  • < 5 min: 100%
  • < 30 min: 90%
  • Livré: 0%

  📊 **TVA:**
  • 20% nourriture
  • 5.5% boissons

  **Benefits:**
  ✅ Sécurisé (PCI-DSS)
  ✅ Anti-fraude
  ✅ Audit complet
end note

note left of primary_adapters
  **ENTRÉES DU SYSTÈME**

  🌐 **REST API:**
  • Traiter paiements
  • Gérer remboursements
  • Consulter factures

  🔔 **BNB Webhook:**
  • Confirmation async
  • payment.success
  • Signature vérifiée

  📨 **Event Listener:**
  • Génère facture auto
  • Réagit aux commandes
end note

note bottom of secondary_adapters
  **SORTIES DU SYSTÈME**

  **BNB Bank:**
  • BNB Bank Payment API
  • 3D Secure (SCA European)
  • Tokenization (no card storage)
  • PCI-DSS Level 1

  **Sift Science:**
  • ML-based fraud detection
  • Real-time scoring
  • Automatic blocking

  **PDF + Email:**
  • Generate with PDFKit
  • Store in S3
  • Send via SendGrid
  • Archive compliant
end note

note as n1
  **FLUX: Traiter Paiement**

  1️⃣ **Client** envoie paiement
  2️⃣ **Fraud Detection** analyse (Sift)
     • Score risque < 50 → OK
     • Score risque ≥ 50 → BLOCK
  3️⃣ **Use Case** orchestre:
     • Initie paiement (Aggregate)
     • Charge carte (BNB Bank)
     • Sauve transaction (Postgres)
  4️⃣ **BNB Bank** traite avec 3D Secure
  5️⃣ **Webhook** confirme async
  6️⃣ **Event Bus** notifie Order Service

  ⏱️ **Temps total: < 3 secondes**

  **Génération facture:**
  • OrderCreatedEvent → Generate invoice
  • Calcul TVA 20%
  • PDF généré (PDFKit)
  • Upload S3
  • Email SendGrid
end note

footer Service FACTURATION - N3 Components | Architecture Hexagonale PCI-DSS

@enduml
