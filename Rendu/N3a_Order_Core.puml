@startuml N3a_Order_Core
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Service COMMANDE - N3a: Cœur Domaine\nAggregate Order + Business Rules

LAYOUT_WITH_LEGEND()

' ====================
' DOMAIN CORE
' ====================
Container_Boundary(domain, "🏢 DOMAIN CORE") {

    Component(order_aggregate, "Order", "Aggregate Root", "**État:**\n• orderId: UUID\n• customerId: UUID\n• status: ENUM\n• items: OrderItem[]\n• totalAmount: Money\n• deliveryAddress: Address\n• createdAt: DateTime\n\n**Méthodes métier:**\n• create()\n• confirm()\n• cancel()\n• canBeCancelled(): boolean")

    Component(order_item, "OrderItem", "Entity", "• productId: UUID\n• productName: string\n• quantity: number\n• unitPrice: Money\n• subtotal: Money")

    Component(delivery_info, "DeliveryInfo", "Value Object", "• address: Address\n• instructions: string\n• estimatedTime: DateTime")

    Component(money, "Money", "Value Object", "• amount: number\n• currency: 'EUR'\n• format(): string\n• add(Money): Money")

    Component(order_status, "OrderStatus", "Enum", "• PENDING\n• CONFIRMED\n• PREPARING\n• READY\n• DELIVERING\n• DELIVERED\n• CANCELLED")
}

Container_Boundary(services, "Domain Services") {
    Component(pricing_service, "PricingService", "Service", "**Calcule:**\n• Sous-total items\n• Frais livraison\n• Total final\n\n**Règles:**\n• Livraison gratuite si > 20€\n• Sinon: 3.50€")

    Component(validation_service, "ValidationService", "Service", "**Valide:**\n• Montant min: 10€\n• Zone de livraison\n• Stock disponible\n• Horaires ouverture")
}

Container_Boundary(events, "Domain Events") {
    Component(order_created, "OrderCreatedEvent", "Event", "• orderId\n• customerId\n• items[]\n• totalAmount\n• timestamp")

    Component(order_cancelled, "OrderCancelledEvent", "Event", "• orderId\n• reason\n• cancelledAt")

    Component(order_confirmed, "OrderConfirmedEvent", "Event", "• orderId\n• confirmedAt")
}

' ====================
' RELATIONS
' ====================
Rel(order_aggregate, order_item, "Contient", "1..*")
Rel(order_aggregate, delivery_info, "A", "1")
Rel(order_aggregate, order_status, "Utilise")
Rel(order_item, money, "Utilise")

Rel(order_aggregate, pricing_service, "Appelle", "calculateTotal()")
Rel(order_aggregate, validation_service, "Appelle", "validate()")

Rel(order_aggregate, order_created, "Produit", "on create()")
Rel(order_aggregate, order_cancelled, "Produit", "on cancel()")
Rel(order_aggregate, order_confirmed, "Produit", "on confirm()")

note right of order_aggregate
  **AGGREGATE ROOT**

  Responsabilités:
  ✅ Garantir invariants métier
  ✅ Coordonner entités
  ✅ Produire événements domaine
  ✅ Point d'entrée unique

  **Invariants protégés:**
  • Status cohérent
  • Items non vides
  • Montant > 10€
  • Adresse valide
end note

note left of pricing_service
  **RÈGLES DE PRICING**

  Calcul total:
  1. Sous-total items
  2. + Frais livraison:
     • Gratuit si > 20€
     • 3.50€ sinon
  3. = Total TTC

  Exemple:
  • 3 Pizzas × 12€ = 36€
  • Livraison = 0€ (>20€)
  • **Total = 36€**
end note

note bottom of validation_service
  **RÈGLES DE VALIDATION**

  ❌ Rejette si:
  • Montant < 10€
  • Zone hors périmètre
  • Restaurant fermé
  • Stock insuffisant

  ✅ Accepte si:
  • Toutes conditions OK
end note

footer Service COMMANDE - N3a: Domain Core | DDD Pattern

@enduml
