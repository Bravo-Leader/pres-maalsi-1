@startuml N3a_Payment_BNB
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Service FACTURATION - N3a: Paiement BNB Bank\nIntégration API Bancaire

LAYOUT_WITH_LEGEND()

System_Ext(client_app, "Client App", "Web/Mobile")

' ====================
' PRIMARY ADAPTER
' ====================
Container_Boundary(primary, "PRIMARY ADAPTER") {
    Component(payment_controller, "PaymentController", "REST API", "POST /api/payments\n\n**Request:**\n```json\n{\n  \"orderId\": \"uuid\",\n  \"amount\": 45.00,\n  \"currency\": \"EUR\",\n  \"cardNumber\": \"****\",\n  \"cvv\": \"***\"\n}\n```")

    Component(bnb_webhook, "BNB Webhook Handler", "HTTP Handler", "POST /webhooks/bnb\n\n**Events:**\n• payment.success\n• payment.failed\n• payment.pending")
}

' ====================
' APPLICATION LAYER
' ====================
Container_Boundary(application, "APPLICATION LAYER") {
    Component(process_payment_usecase, "ProcessPaymentUseCase", "Use Case", "**Étapes:**\n1. Valider montant\n2. Vérifier fraude\n3. Appeler BNB API\n4. Sauvegarder transaction\n5. Publier événement")

    Component(confirm_payment_usecase, "ConfirmPaymentUseCase", "Use Case", "**Étapes:**\n1. Valider webhook BNB\n2. Confirmer paiement\n3. Mettre à jour statut\n4. Notifier commande")
}

' ====================
' DOMAIN LAYER
' ====================
Container_Boundary(domain, "DOMAIN LAYER") {
    Component(payment, "Payment", "Aggregate Root", "**État:**\n• paymentId\n• orderId\n• amount\n• status\n• transactionId (BNB)\n• createdAt\n\n**Méthodes:**\n• initiate()\n• confirm()\n• fail()")

    Component(fraud_detector, "FraudDetector", "Domain Service", "**Détecte:**\n• Montant anormal\n• Carte bloquée\n• Adresse suspecte\n\n**Score risque:**\n• < 50: OK\n• ≥ 50: BLOCK")

    Component(payment_confirmed, "PaymentConfirmedEvent", "Event", "• paymentId\n• orderId\n• transactionId\n• amount")
}

' ====================
' PORTS
' ====================
Container_Boundary(ports, "PORTS") {
    Component(payment_repo_port, "IPaymentRepository", "Port", "save(payment)\nfindById(id)")

    Component(payment_gateway_port, "IPaymentGateway", "Port", "charge(amount, card)\ngetStatus(transactionId)")
}

' ====================
' SECONDARY ADAPTERS
' ====================
Container_Boundary(secondary, "SECONDARY ADAPTERS") {
    Component(postgres_adapter, "PostgresPaymentRepository", "Adapter", "INSERT INTO payments")

    Component(bnb_adapter, "BNBBankAdapter", "Adapter", "**API BNB Bank:**\n\nPOST /api/v1/payments\n```json\n{\n  \"amount\": 45.00,\n  \"currency\": \"EUR\",\n  \"cardToken\": \"...\",\n  \"merchant\": \"GOODFOOD\"\n}\n```\n\n**3D Secure:**\nRedirect client si > 30€")

    Component(event_publisher, "RabbitMQPublisher", "Adapter", "Publish events")
}

' ====================
' INFRASTRUCTURE
' ====================
ContainerDb(postgres, "PostgreSQL", "Database", "payments table")
Container(rabbitmq, "RabbitMQ", "Event Bus")
System_Ext(bnb_bank, "BNB Bank API", "External", "API bancaire\nhttps://api.bnb.com")

' ====================
' FLOW: PROCESS PAYMENT
' ====================
Rel(client_app, payment_controller, "1. POST /api/payments", "HTTPS")
Rel(payment_controller, process_payment_usecase, "2. Execute", "DTO")

Rel(process_payment_usecase, fraud_detector, "3. Check fraud", "Domain service")

Rel(process_payment_usecase, payment, "4. Payment.initiate()", "Aggregate")

Rel(process_payment_usecase, payment_gateway_port, "5. charge()", "Port")
Rel(payment_gateway_port, bnb_adapter, "6. Implémente", "")
Rel(bnb_adapter, bnb_bank, "7. POST /api/v1/payments", "HTTPS")

Rel(bnb_bank, bnb_adapter, "8. Response", "transactionId")

Rel(process_payment_usecase, payment_repo_port, "9. save()", "Port")
Rel(payment_repo_port, postgres_adapter, "10. Implémente", "")
Rel(postgres_adapter, postgres, "11. INSERT", "SQL")

Rel(payment_controller, client_app, "12. Response", "201 Created")

' ====================
' FLOW: WEBHOOK CONFIRMATION
' ====================
Rel(bnb_bank, bnb_webhook, "payment.success", "Webhook async")
Rel(bnb_webhook, confirm_payment_usecase, "Execute", "")
Rel(confirm_payment_usecase, payment, "confirm()", "")
Rel(payment, payment_confirmed, "Raise event", "")
Rel(confirm_payment_usecase, event_publisher, "publish()", "")
Rel(event_publisher, rabbitmq, "Send", "AMQP")

note right of bnb_adapter
  **API BNB BANK**

  **Authentification:**
  • API Key dans header
  • Bearer token OAuth2

  **3D Secure:**
  • Obligatoire si > 30€
  • Redirect client
  • Callback URL

  **Endpoints:**
  • POST /payments (créer)
  • GET /payments/:id (statut)
  • POST /refunds (rembourser)

  **Response:**
  ```json
  {
    "transactionId": "BNB-xxx",
    "status": "SUCCESS",
    "amount": 45.00
  }
  ```
end note

note left of fraud_detector
  **ANTI-FRAUDE**

  **Analyse:**
  1. Montant inhabituel?
  2. Carte déjà bloquée?
  3. Adresse IP suspecte?
  4. Nombreuses tentatives?

  **Score risque:**
  • 0-30: Faible ✅
  • 31-49: Moyen ⚠️
  • 50+: Élevé ❌ BLOCK

  **Action si bloqué:**
  • Log incident
  • Notifier admin
  • Retourner erreur 403
end note

note as timing
  **FLUX TEMPOREL**

  1️⃣ Client envoie paiement
  2️⃣ Fraud detection (< 100ms)
  3️⃣ Appel BNB API (~ 1-2s)
     • 3D Secure si > 30€
  4️⃣ Sauvegarde transaction
  5️⃣ Response au client

  **Async:**
  ⏱️ 5-10s plus tard:
  • BNB webhook confirme
  • PaymentConfirmedEvent
  • Order Service notifié

  **Total:** < 3 secondes
end note

footer Service FACTURATION - N3a: BNB Bank Integration | REST API Only

@enduml
