@startuml N3b_Order_CreateFlow
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Service COMMANDE - N3b: Flux Création\nREST API → Domain → Database → Events

LAYOUT_WITH_LEGEND()

System_Ext(client_app, "Client Web/Mobile", "Application")

' ====================
' PRIMARY ADAPTER
' ====================
Container_Boundary(primary, "PRIMARY ADAPTER") {
    Component(order_controller, "OrderController", "REST API", "POST /api/orders\n\n**Request Body:**\n```json\n{\n  \"customerId\": \"uuid\",\n  \"restaurantId\": \"uuid\",\n  \"items\": [\n    {\n      \"productId\": \"uuid\",\n      \"quantity\": 2\n    }\n  ],\n  \"deliveryAddress\": {...}\n}\n```")
}

' ====================
' APPLICATION LAYER
' ====================
Container_Boundary(application, "APPLICATION LAYER") {
    Component(create_order_usecase, "CreateOrderUseCase", "Use Case", "**Steps:**\n1. Valider entrée\n2. Vérifier stock (via port)\n3. Calculer prix\n4. Créer Order aggregate\n5. Sauvegarder (via port)\n6. Publier événement")
}

' ====================
' DOMAIN LAYER
' ====================
Container_Boundary(domain, "DOMAIN LAYER") {
    Component(order, "Order", "Aggregate", "create()\nvalidate()\ncalculateTotal()")

    Component(pricing_service, "PricingService", "Service", "calculateTotal()")

    Component(order_created_event, "OrderCreatedEvent", "Event", "Domain event")
}

' ====================
' PORTS (INTERFACES)
' ====================
Container_Boundary(ports, "PORTS (Interfaces)") {
    Component(order_repo_port, "IOrderRepository", "Port", "save(order)")

    Component(inventory_port, "IInventoryService", "Port", "checkStock(items)")

    Component(event_port, "IEventPublisher", "Port", "publish(event)")
}

' ====================
' SECONDARY ADAPTERS
' ====================
Container_Boundary(secondary, "SECONDARY ADAPTERS") {
    Component(postgres_adapter, "PostgresOrderRepository", "Adapter", "**Implémente:**\nIOrderRepository\n\n**SQL:**\nINSERT INTO orders (...)\nVALUES (...)")

    Component(inventory_adapter, "InventoryServiceClient", "Adapter", "**Implémente:**\nIInventoryService\n\n**HTTP:**\nGET /api/stock/check")

    Component(rabbitmq_adapter, "RabbitMQPublisher", "Adapter", "**Implémente:**\nIEventPublisher\n\n**AMQP:**\nPublish to exchange")
}

' ====================
' INFRASTRUCTURE
' ====================
ContainerDb(postgres, "PostgreSQL", "Database", "orders table")
Container(rabbitmq, "RabbitMQ", "Event Bus", "orders exchange")
System_Ext(inventory_service, "Service Stock", "Microservice")

' ====================
' FLOW
' ====================
Rel(client_app, order_controller, "1. POST /api/orders", "HTTPS/JSON")
Rel(order_controller, create_order_usecase, "2. Execute", "CreateOrderDTO")

Rel(create_order_usecase, inventory_port, "3. checkStock(items)", "Port call")
Rel(inventory_port, inventory_adapter, "4. Implémente", "")
Rel(inventory_adapter, inventory_service, "5. GET /api/stock/check", "REST API")

Rel(create_order_usecase, pricing_service, "6. calculateTotal()", "Domain service")

Rel(create_order_usecase, order, "7. Order.create()", "Aggregate")
Rel(order, order_created_event, "8. Raise event", "Domain event")

Rel(create_order_usecase, order_repo_port, "9. save(order)", "Port call")
Rel(order_repo_port, postgres_adapter, "10. Implémente", "")
Rel(postgres_adapter, postgres, "11. INSERT", "SQL")

Rel(create_order_usecase, event_port, "12. publish(event)", "Port call")
Rel(event_port, rabbitmq_adapter, "13. Implémente", "")
Rel(rabbitmq_adapter, rabbitmq, "14. Send", "AMQP")

Rel(order_controller, client_app, "15. Response", "201 Created\n{orderId, status}")

note as flow
  **FLUX COMPLET**

  1️⃣ Client envoie POST /api/orders
  2️⃣ Controller délègue au Use Case
  3️⃣ Use Case vérifie stock (Service Stock)
  4️⃣ Calcule prix (Domain Service)
  5️⃣ Crée Order aggregate
  6️⃣ Sauvegarde Postgres (via Port)
  7️⃣ Publie OrderCreatedEvent
  8️⃣ Retourne 201 Created

  ⏱️ **Temps:** < 500ms
end note

note right of ports
  **PATTERN PORTS & ADAPTERS**

  **Port = Interface (contrat)**
  • Défini dans Domain Layer
  • Pas de dépendance technique

  **Adapter = Implémentation**
  • Dans Infrastructure Layer
  • Détails techniques (Postgres, HTTP)

  **Bénéfice:**
  ✅ Domain indépendant
  ✅ Facilement testable
  ✅ Changement facile (Postgres → Mongo)
end note

footer Service COMMANDE - N3b: Create Order Flow | Hexagonal Architecture

@enduml
